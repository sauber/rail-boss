---
// src/layouts/Layout.astro
import StartupModal from '../components/StartupModal.astro';
import Map from '../components/Map.astro';
import ControlPanel from '../components/ControlPanel.astro';
---

<div class="game-container">
  <div class="map-view">
    <Map />
  </div>
  <div class="control-panel">
    <ControlPanel />
  </div>
  <StartupModal />
</div>

<script>
  // Import GameState class for client-side use
  import { GameState } from '../lib/GameState.ts';
  
  // Initialize game state with stations including positions
  const init = async () => {
    const gameState = new GameState();
    // Store globally for other components
    (window as any).gameState = gameState;
    // Dispatch initial state event
    const event = new CustomEvent('game-state-update', { detail: gameState });
    window.dispatchEvent(event);
  };
  init();
</script>

<style>
  .game-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .map-view {
    flex: 2;
    min-height: 0;
    position: relative;
  }
  .control-panel {
    flex: 1;
    min-height: 0;
    position: relative;
    z-index: 1;
  }
  .startup-modal {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 10;
  }
</style>
