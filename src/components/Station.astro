---
/**
 * Astro component for rendering a Station.
 * Expects a `station` prop as a plain object with station properties.
 */
interface Props {
  station: {
    id: string;
    name: string;
    colour: string;
    size: number;          // platform count used as radius multiplier
    x: number;
    y: number;
    platforms: number;
    waitingPassengers: number;
  };
}
const { station } = Astro.props;
---
<g data-station-id={station.id}>
  <!-- Circle representing the station -->
  <circle
    cx={station.x}
    cy={station.y}
    r={station.size * 5}
    fill={station.colour}
    stroke="#000"
    stroke-width="2"
  />
  <!-- Station name label -->
  <text
    x={station.x}
    y={station.y - (station.size * 5) - 5}
    text-anchor="middle"
    font-size="12"
    fill="#fff"
  >{station.name}</text>
</g>
